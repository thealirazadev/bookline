# Postgres connection string used by Prisma (docker-compose default shown).
DATABASE_URL=postgresql://bookline:bookline@localhost:5432/bookline

# Auth.js session signing secret. Generate with: openssl rand -base64 32
AUTH_SECRET=dummy-auth-secret-change-me

# HMAC key for cancel/reschedule manage-link tokens. Keep distinct from AUTH_SECRET.
LINK_TOKEN_SECRET=dummy-link-token-secret-change-me

# Absolute base URL used to build links in emails and the iCal feed.
APP_BASE_URL=http://localhost:3000

# SMTP relay. Defaults target the Mailpit dev mailbox from docker-compose (UI on :8025).
SMTP_HOST=localhost
SMTP_PORT=1025

# SMTP credentials; leave empty for Mailpit.
SMTP_USER=
SMTP_PASS=

# From header on all outgoing mail.
MAIL_FROM=Bookline <bookings@example.com>

# Initial host account, consumed only by prisma/seed.ts.
SEED_HOST_EMAIL=host@example.com
SEED_HOST_PASSWORD=change-me-immediately
SEED_HOST_NAME=Example Host

# IANA timezone the host's availability rules are defined in.
SEED_HOST_TIMEZONE=Europe/Berlin
