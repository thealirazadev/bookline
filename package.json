{
  "name": "bookline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project unit",
    "test:watch": "vitest",
    "test:integration": "vitest run --project integration",
    "test:e2e": "playwright test",
    "db:seed": "prisma db seed",
    "reminders:once": "tsx jobs/reminders.ts",
    "bench": "tsx scripts/benchmark.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "3.0.3",
    "luxon": "3.7.2",
    "next": "15.5.20",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "9.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "3.25.76"
  },
  "overrides": {
    "next-auth": {
      "nodemailer": "$nodemailer"
    },
    "next": {
      "postcss": "8.5.21",
      "sharp": "0.35.3"
    }
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/luxon": "3.7.2",
    "@types/node": "22.20.1",
    "@types/nodemailer": "8.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.4",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.20",
    "jsdom": "29.1.1",
    "postcss": "8.5.21",
    "prettier": "3.9.5",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.19",
    "tsx": "4.23.1",
    "typescript": "7.0.2",
    "vitest": "3.2.7"
  }
}
